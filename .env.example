# Copy to .env.local for local development.
# Leave Notion values unset to stay in mock/local-only mode.
#
# The app reads NOTION_API_KEY (not NOTION_TOKEN). If only NOTION_TOKEN is set,
# sync stays disabled and the app runs entirely on the local SQLite mock seed.
#
# Setting NOTION_API_KEY + a NOTION_DATABASE_* id only enables the read-only
# schema check in Settings ("Notion Database Mapping") - it never reads row
# data and never writes. Real push/pull sync (writes to Notion, imports rows
# into local SQLite) additionally requires NOTION_SYNC_ENABLED=true. See
# docs/notion-setup.md for creating the six databases and
# docs/notion-migration-plan.md before ever setting NOTION_SYNC_ENABLED=true.

# Notion (optional — app works without these)
NOTION_API_KEY=

# All six database ids below are required for full sync, but each is
# independently optional - the read-only mapping check reports exactly which
# ones are configured/accessible/schema-valid regardless of how many are set.
NOTION_DATABASE_CLIENTS=
NOTION_DATABASE_PROJECTS=
NOTION_DATABASE_HOURS=
NOTION_DATABASE_WORKLOGS=
NOTION_DATABASE_KNOWLEDGE=
NOTION_DATABASE_INVOICES=

NOTION_SYNC_INTERVAL_MINUTES=5

# Master switch for real push/pull sync. Defaults to false (read-only mapping
# only) even when the API key and database ids above are set. Do not set this
# to "true" until you've reviewed docs/notion-migration-plan.md and are ready
# to import/push real data.
NOTION_SYNC_ENABLED=false
