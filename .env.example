# Runtime mode: mock uses local SQLite; notion reads/writes Notion directly.
# Vercel production requires notion. Local development defaults to mock when omitted.
APP_DATA_SOURCE=mock

# Required in notion mode. Keep these server-only (never NEXT_PUBLIC_*).
NOTION_API_KEY=
NOTION_DATABASE_CLIENTS=
NOTION_DATABASE_PROJECTS=
NOTION_DATABASE_HOURS=
NOTION_DATABASE_WORKLOGS=
NOTION_DATABASE_KNOWLEDGE=
NOTION_DATABASE_INVOICES=

# The legacy general sync/import engine must remain disabled. Notion-native
# targeted POST/PATCH actions are separate and validate the target schema.
NOTION_SYNC_ENABLED=false

# Explicit invoice save to Notion (Phase 13). Remains false until approved.
NOTION_INVOICE_SAVE_ENABLED=false

# Private-app protection. Basic Auth is the portable fallback. On Vercel you
# may instead enable Deployment Protection in the dashboard and set its
# confirmation flag below so production configuration validation can pass.
APP_ACCESS_USERNAME=austin
APP_ACCESS_PASSWORD=
VERCEL_DEPLOYMENT_PROTECTION=false

# Optional environment-managed report identity in notion mode.
REPORT_CONTRACTOR_NAME=
REPORT_BUSINESS_NAME=
REPORT_EMAIL=
REPORT_PHONE=
REPORT_ADDRESS=
REPORT_DEFAULT_HOURLY_RATE=30
REPORT_DEFAULT_PAYMENT_TERMS=Due on receipt
REPORT_DEFAULT_INVOICE_NOTES=
REPORT_LOGO_PATH=
REPORT_CLIENT_DISPLAY_NAME=
REPORT_CLIENT_BILLING_CONTACT=
REPORT_CLIENT_BILLING_EMAIL=
